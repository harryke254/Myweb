rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "harrisonreycaspian@gmail.com" ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    match /mixes/{allPaths=**} {
      allow read: if true;
      // Allow admin to upload files up to 500MB
      allow write: if isAdmin() && request.resource.size < 500 * 1024 * 1024;
    }
    
    match /images/{allPaths=**} {
      allow read: if true;
      // Allow admin to upload images up to 10MB
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
