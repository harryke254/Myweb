rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidMix() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['title', 'genre', 'audioUrl', 'imageUrl', 'duration', 'plays', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.genre is string && data.genre.size() > 0 && data.genre.size() < 50 &&
             data.audioUrl is string && data.audioUrl.size() < 1000 &&
             data.imageUrl is string && data.imageUrl.size() < 1000 &&
             data.duration is string && data.duration.size() < 20 &&
             data.plays is number && data.plays >= 0 &&
             data.createdAt is string;
    }
    
    function isValidEvent() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['title', 'date', 'day', 'venue', 'location', 'status', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.date is string && data.date.size() > 0 && data.date.size() < 20 &&
             data.day is string && data.day.size() > 0 && data.day.size() < 20 &&
             data.venue is string && data.venue.size() > 0 && data.venue.size() < 100 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 100 &&
             data.status is string && data.status in ['Available', 'Selling Fast', 'Sold Out'] &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /mixes/{mixId} {
      allow read: if true;
      allow create: if isValidMix();
      allow update: if isValidMix();
      allow delete: if true;
    }
    
    match /events/{eventId} {
      allow read: if true;
      allow create: if isValidEvent();
      allow update: if isValidEvent();
      allow delete: if true;
    }
  }
}
